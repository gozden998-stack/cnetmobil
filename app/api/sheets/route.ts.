// app/api/sheets/route.ts
import { NextResponse } from 'next/server';

export async function GET() {
  const SHEET_ID = process.env.SHEET_ID; // NEXT_PUBLIC yok, güvenli!
  const API_KEY = process.env.API_KEY;

  // Çekmek istediğin tüm tabloları buraya ekledim
  const tables = [
    { name: 'Devices', range: 'Google Sheets ile Kurumsal Alım Sistemi!A2:F1000' },
    { name: 'Ayarlar', range: 'Ayarlar!A1:B25' },
    { name: 'Alimlar', range: 'Alimlar!A2:H500' },
    { name: 'Markalar', range: 'Markalar!A2:B50' },
    { name: 'Servis', range: 'Servis_Fiyatlari!A2:G1000' }
  ];

  try {
    const results: any = {};
    for (const table of tables) {
      const url = `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/${encodeURIComponent(table.range)}?key=${API_KEY}`;
      const res = await fetch(url);
      const data = await res.json();
      results[table.name] = data.values || [];
    }
    return NextResponse.json(results);
  } catch (error) {
    return NextResponse.json({ error: "Sunucu hatası" }, { status: 500 });
  }
}
